-- Function to kick a player (client-side kick from the script)
local function kickPlayerFromScript(targetPlayer, reason)
    if not targetPlayer then return false end
    
    -- This kicks them from the SCRIPT (not the game server)
    -- Their script will stop working
    pcall(function()
        -- Remove their ScriptLoaded tag so they can't use features
        local tag = targetPlayer:FindFirstChild("ScriptLoaded")
        if tag then
            tag:Destroy()
        end
        
        -- Notify them
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "❌ KICKED FROM SCRIPT",
            Text = "You have been kicked from using this script by owner @capmPH\nReason: " .. reason,
            Duration = 10
        })
        
        -- Clear their GUI or break their script (they need to re-execute)
        -- This effectively removes script access
    end)
    
    -- Notify owner
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "✅ Player Kicked",
        Text = targetPlayer.Name .. " has been kicked from using your script!",
        Duration = 3
    })
    
    return true
end

-- Check if an attacker is using your script
local function isUsingScript(player)
    return player and player:FindFirstChild("ScriptLoaded") ~= nil
end

-- Detect when you get hit
local function setupHitDetection()
    local character = localPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    -- Listen for damage
    local connection
    connection = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if not autoKickScriptUsers then return end
        
        local currentHealth = humanoid.Health
        local lastHealth = humanoid:GetAttribute("LastHealth") or currentHealth
        
        -- If health decreased (got hit)
        if currentHealth < lastHealth then
            local damage = lastHealth - currentHealth
            
            -- Find who hit you by checking nearby players with weapons
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= localPlayer and isUsingScript(player) then
                    local char = player.Character
                    if char then
                        local rootPart = char:FindFirstChild("HumanoidRootPart")
                        local myRoot = character:FindFirstChild("HumanoidRootPart")
                        if rootPart and myRoot then
                            local dist = (rootPart.Position - myRoot.Position).Magnitude
                            -- If they're close (within attack range), they probably hit you
                            if dist <= 15 then
                                kickPlayerFromScript(player, "Hit the script owner!")
                                notifyAllUsers(player.Name .. " was kicked for attacking " .. localPlayer.Name, "🔨 AUTO-KICK")
                                break
                            end
                        end
                    end
                end
            end
        end
        
        humanoid:SetAttribute("LastHealth", currentHealth)
    end)
    
    -- Store connection for cleanup
    _G.hitDetectionConnection = connection
end

