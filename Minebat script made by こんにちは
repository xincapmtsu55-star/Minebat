-- Kick function
local function kickFromScript(target, reason)
    local tag = target:FindFirstChild("ScriptLoaded")
    if tag then
        tag:Destroy()
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Kicked",
                Text = "Kicked by owner: " .. reason,
                Duration = 5
            })
        end)
    end
end

-- Notify all users
local function notifyAll(msg, title)
    for _, p in pairs(Players:GetPlayers()) do
        if p:FindFirstChild("ScriptLoaded") then
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = title or "Alert",
                    Text = msg,
                    Duration = 5
                })
            end)
        end
    end
end

