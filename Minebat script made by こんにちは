-- Get current weapon
local function getCurrentWeapon()
    local character = localPlayer.Character
    if not character then return "Iron Sword" end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        return tool.Name
    end
    
    return "Iron Sword"
end

-- Function to reset weapon
local function resetWeapon()
    local character = localPlayer.Character
    if not character then return end
    
    local currentTool = character:FindFirstChildOfClass("Tool")
    if not currentTool then return end
    
    local toolName = currentTool.Name
    local backpack = localPlayer:FindFirstChildOfClass("Backpack")
    
    currentTool.Parent = backpack
    task.wait(0.1)
    
    local toolInBackpack = backpack and backpack:FindFirstChild(toolName)
    if toolInBackpack then
        toolInBackpack.Parent = character
    end
end

-- Distance check
local function isInRange(targetChar, myPos)
    if not targetChar then return false end
    local rootPart = targetChar:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    return (rootPart.Position - myPos).Magnitude <= attackRange
end

-- Attack function
local function attackTarget(targetChar)
    if not targetChar or not Remote then return end
    local weapon = getCurrentWeapon()
    local args = {
        [1] = targetChar,
        [2] = 1,
        [4] = weapon
    }
    pcall(function()
        Remote:FireServer(unpack(args))
    end)
end

-- Get targets
local function getTargets()
    local targets = {}
    local myChar = localPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return targets end
    
    local myPos = myChar.HumanoidRootPart.Position
    
    -- Player targets
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer then
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") and isInRange(char, myPos) then
                table.insert(targets, char)
            end
        end
    end
    
    -- AI targets
    local aiFolder = Workspace:FindFirstChild("Ai")
    if aiFolder then
        local mainAi = aiFolder:FindFirstChild("Ai")
        if mainAi and mainAi:FindFirstChild("HumanoidRootPart") and isInRange(mainAi, myPos) then
            table.insert(targets, mainAi)
        end
        
        local minionAi = aiFolder:FindFirstChild("Minion Ai")
        if minionAi and minionAi:FindFirstChild("HumanoidRootPart") and isInRange(minionAi, myPos) then
            table.insert(targets, minionAi)
        end
        
        local juggernautAi = aiFolder:FindFirstChild("Juggernaut Ai")
        if juggernautAi and juggernautAi:FindFirstChild("HumanoidRootPart") and isInRange(juggernautAi, myPos) then
            table.insert(targets, juggernautAi)
        end
    end
    
    return targets
end

-- Auto Golden Apple
local autoGoldenAppleEnabled = false
local goldenAppleHealthThreshold = 50
local goldenAppleCooldown = false
local lastGoldenAppleTime = 0
local goldenAppleDelay = 5

local function useGoldenApple()
    if not autoGoldenAppleEnabled or goldenAppleCooldown then return end
    
    local now = tick()
    if now - lastGoldenAppleTime < goldenAppleDelay then return end
    
    local character = localPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local healthPercent = (humanoid.Health / humanoid.MaxHealth) * 100
    
    if healthPercent <= goldenAppleHealthThreshold then
        local goldenApple = character:FindFirstChild("Golden Apple")
        if goldenApple and goldenApple:FindFirstChild("Data") then
            pcall(function()
                goldenApple.Data:FireServer(false, false)
                task.wait(0.1)
                goldenApple.Data:FireServer(false, true)
                task.wait(0.1)
                goldenApple.Data:FireServer(true)
            end)
            
            lastGoldenAppleTime = now
            goldenAppleCooldown = true
            task.spawn(function()
                task.wait(goldenAppleDelay)
                goldenAppleCooldown = false
            end)
        end
    end
end

-- KillAura loop
local lastAttack = 0
local killAuraConnection = nil

local function startKillAura()
    if killAuraConnection then killAuraConnection:Disconnect() end
    
    killAuraConnection = RunService.Heartbeat:Connect(function()
        if not killAuraEnabled then return end
        
        local now = tick()
        if now - lastAttack < attackDelay then return end
        
        local myChar = localPlayer.Character
        if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
        
        local targets = getTargets()
        if #targets > 0 then
            if multiHitEnabled then
                for _, target in pairs(targets) do
                    attackTarget(target)
                end
            else
                attackTarget(targets[math.random(1, #targets)])
            end
            lastAttack = now
        end
    end)
end

-- Auto Golden Apple loop
local goldenAppleConnection = nil

local function startAutoGoldenApple()
    if goldenAppleConnection then goldenAppleConnection:Disconnect() end
    goldenAppleConnection = RunService.Heartbeat:Connect(function()
        useGoldenApple()
    end)
end

