-- Variables
local killAura = false
local multiHit = false
local range = 30
local delay = 0.5
local lastAttack = 0
local connection = nil
local weaponCategory = "Sword" -- Sword or Axe

-- Weapon lists
local swords = {"Iron Sword", "Golden Sword", "Diamond Sword", "Netherite Sword"}
local axes = {"Iron Axe", "Golden Axe", "Diamond Axe", "Netherite Axe"}

-- Get current weapon
local function getWeapon()
    local char = localPlayer.Character
    if not char then return nil end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return nil end
    
    if weaponCategory == "Sword" then
        for _, w in pairs(swords) do
            if tool.Name == w then return w end
        end
    else
        for _, w in pairs(axes) do
            if tool.Name == w then return w end
        end
    end
    return nil
end

-- Reset weapon
local function resetWeapon()
    local char = localPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    local name = tool.Name
    local backpack = localPlayer:FindFirstChildOfClass("Backpack")
    tool.Parent = backpack
    task.wait(0.1)
    local newTool = backpack:FindFirstChild(name)
    if newTool then newTool.Parent = char end
end

-- Range check
local function inRange(target, pos)
    local root = target:FindFirstChild("HumanoidRootPart")
    return root and (root.Position - pos).Magnitude <= range
end

-- Get targets
local function getTargets()
    local targets = {}
    local char = localPlayer.Character
    if not char then return targets end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return targets end
    local myPos = root.Position
    
    -- Players
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer then
            local targetChar = p.Character
            if targetChar and inRange(targetChar, myPos) then
                table.insert(targets, targetChar)
            end
        end
    end
    
    -- AI
    local ai = Workspace:FindFirstChild("Ai")
    if ai then
        for _, name in pairs({"Ai", "Minion Ai", "Juggernaut Ai"}) do
            local target = ai:FindFirstChild(name)
            if target and inRange(target, myPos) then
                table.insert(targets, target)
            end
        end
    end
    
    return targets
end

-- Attack
local function attack(target)
    if not target or not Remote then return end
    local weapon = getWeapon()
    if not weapon then return end
    pcall(function()
        Remote:FireServer(target, 1, nil, weapon)
    end)
end

-- Hit detection for auto-kick
local function setupHitDetection()
    local char = localPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    local lastHealth = hum.Health
    hum:GetPropertyChangedSignal("Health"):Connect(function()
        if not autoKickEnabled then return end
        if hum.Health < lastHealth then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= localPlayer and p:FindFirstChild("ScriptLoaded") then
                    local pChar = p.Character
                    if pChar and pChar:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("HumanoidRootPart") then
                        local dist = (pChar.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                        if dist <= 20 then
                            kickFromScript(p, "Attacked owner")
                            notifyAll(p.Name .. " was auto-kicked for attacking " .. localPlayer.Name, "Auto-Kick")
                        end
                    end
                end
            end
        end
        lastHealth = hum.Health
    end)
end

-- KillAura loop
local function startKillAura()
    if connection then connection:Disconnect() end
    connection = RunService.Heartbeat:Connect(function()
        if not killAura then return end
        local now = tick()
        if now - lastAttack < delay then return end
        if not getWeapon() then return end
        local targets = getTargets()
        if #targets > 0 then
            if multiHit then
                for _, t in pairs(targets) do attack(t) end
            else
                attack(targets[math.random(#targets)])
            end
            lastAttack = now
        end
    end)
end

-- Auto Golden Apple
local appleEnabled = false
local appleHealth = 50
local appleCD = false
local lastApple = 0
local appleDelay = 5
local appleConnection = nil

local function useApple()
    if not appleEnabled or appleCD then return end
    if tick() - lastApple < appleDelay then return end
    local char = localPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if (hum.Health / hum.MaxHealth) * 100 <= appleHealth then
        local apple = char:FindFirstChild("Golden Apple")
        if apple and apple:FindFirstChild("Data") then
            pcall(function()
                apple.Data:FireServer(false, false)
                task.wait(0.1)
                apple.Data:FireServer(false, true)
                task.wait(0.1)
                apple.Data:FireServer(true)
            end)
            lastApple = tick()
            appleCD = true
            task.spawn(function() task.wait(appleDelay) appleCD = false end)
        end
    end
end

local function startApple()
    if appleConnection then appleConnection:Disconnect() end
    appleConnection = RunService.Heartbeat:Connect(useApple)
end

-- Respawn
localPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    setupHitDetection()
end)

