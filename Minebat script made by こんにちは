-- ============ TROLL FUNCTIONS ============

-- Fling function (silent - no notification)
local function flingPlayer(targetPlayer)
    local targetChar = targetPlayer.Character
    if not targetChar then return end
    local humanoidRootPart = targetChar:FindFirstChild("HumanoidRootPart")
    local humanoid = targetChar:FindFirstChildOfClass("Humanoid")
    if not humanoidRootPart or not humanoid then return end
    
    -- Save original state
    local originalPlatformStand = humanoid.PlatformStand
    
    -- Enable platform stand
    humanoid.PlatformStand = true
    
    -- Create random fling direction
    local direction = Vector3.new(math.random(-100, 100), math.random(50, 150), math.random(-100, 100))
    local velocity = direction.Unit * 350
    
    -- Apply velocity
    humanoidRootPart.Velocity = velocity
    humanoidRootPart.AssemblyLinearVelocity = velocity
    
    -- Add a slight rotation for extra effect
    humanoidRootPart.AssemblyAngularVelocity = Vector3.new(math.random(-50, 50), math.random(-50, 50), math.random(-50, 50))
    
    -- Create a body velocity to keep flinging for a bit
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bodyVelocity.Velocity = velocity
    bodyVelocity.Parent = humanoidRootPart
    
    -- Clean up after 2 seconds
    task.wait(2)
    bodyVelocity:Destroy()
    
    -- Restore
    humanoid.PlatformStand = originalPlatformStand
end

-- Reset player function (silent - no notification)
local function resetPlayer(targetPlayer)
    local char = targetPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.Health = 0
        end
    end
end

-- Notify function (owner to specific player - only for manual messages)
local function notifyPlayer(targetPlayer, message, title)
    if targetPlayer and targetPlayer:FindFirstChild("ScriptLoaded") then
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = title or "Owner Message",
                Text = message,
                Duration = 5
            })
        end)
    end
end

-- Notify all script users (only for manual messages)
local function notifyAllScriptUsers(message, title)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p:FindFirstChild("ScriptLoaded") then
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = title or "Owner Broadcast",
                    Text = message,
                    Duration = 5
                })
            end)
        end
    end
end

