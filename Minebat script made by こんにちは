-- Function to notify all players using the script
local function notifyAllUsers(message, title)
    for _, player in pairs(Players:GetPlayers()) do
        if player:FindFirstChild("ScriptLoaded") then
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
